# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# Required: OpenAI API key for LLM calls
OPENAI_API_KEY=sk-...

# Optional: Tavily web search (required for web_search tool)
TAVILY_API_KEY=tvly-...

# Optional: PDF vector store paths (required for pdf_search tool)
DATA_DIR=/path/to/your/pdfs/
CHROMA_DIR=/path/to/your/chroma_db/
